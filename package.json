{
  "name": "ocm",
  "version": "0.1.0",
  "description": "OpenClaw Manager — 一站式安装 & 管理工具，专为中文用户和国内网络优化",
  "type": "module",
  "bin": {
    "ocm": "./dist/index.js"
  },
  "files": [
    "dist",
    "install.sh",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "prepare": "tsup",
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run build && npm test"
  },
  "keywords": [
    "openclaw",
    "ai",
    "cli",
    "installer",
    "manager",
    "model-switch",
    "chinese",
    "telegram",
    "discord",
    "feishu"
  ],
  "author": "xpangjia",
  "license": "MIT",
  "homepage": "https://github.com/xpangjia/ocm#readme",
  "bugs": {
    "url": "https://github.com/xpangjia/ocm/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xpangjia/ocm.git"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "commander": "^13.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.4"
  }
}
